# Host port exposed by docker compose. The container listens on 8808.
VOXCPM_HOST_PORT=

# Runtime device: auto, cpu, cuda, or cuda:N.
VOXCPM_DEVICE=auto

# Container timezone (IANA name), used for log timestamps and scheduling.
TZ=Asia/Shanghai

# Host directory for large Docker assets: models, caches, data, outputs, and Gradio temp files.
# The example defaults to the current project directory. For production, set this
# in .env to a storage drive with enough free space, for example D:/DockerRes/VoxCPM.
VOXCPM_ASSET_ROOT=.

# Default uses the pre-downloaded model bind-mounted from ${VOXCPM_ASSET_ROOT}/models/VoxCPM2.
# To let the container download from Hugging Face instead, use: openbmb/VoxCPM2
VOXCPM_MODEL_ID=/models/VoxCPM2

# Hugging Face token used by this project's bundled hf-xet scripts.
# Copy this file to .env, then set HF_Token if you need authenticated HF downloads.
# The application and download scripts read .env directly; .env.example is documentation/template only.
HF_Token=