# Host port exposed by docker compose. The container listens on 8808.
VOXCPM_HOST_PORT=

# Runtime device: auto, cpu, cuda, or cuda:N.
VOXCPM_DEVICE=auto

# Container timezone (IANA name), used for log timestamps and scheduling.
TZ=Asia/Shanghai

# Host directory for large Docker assets: models, caches, data, outputs, and Gradio temp files.
# The example defaults to the current project directory. For production, set this
# in .env to a storage drive with enough free space, for example D:/DockerRes/VoxCPM.
VOXCPM_ASSET_ROOT=.

# Default uses the model downloaded inside the container at startup, into the
# bind-mounted ${VOXCPM_ASSET_ROOT}/models/VoxCPM2 (so weights stay out of the image).
# To let the app resolve/download from Hugging Face at load time instead, use: openbmb/VoxCPM2
VOXCPM_MODEL_ID=/models/VoxCPM2

# Hugging Face token for authenticated / accelerated model downloads.
# Copy this file to .env, then set HF_Token to enable authenticated HF downloads.
# It is passed into the container (as HF_TOKEN) and used by the in-container
# download step. Leave empty for anonymous access. .env.example is template only.
HF_Token=